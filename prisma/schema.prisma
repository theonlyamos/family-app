generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  middleName  String?
  gender      String?
  dob         DateTime?
  dod         DateTime?
  pob         String?
  occupation  String?
  
  // Contact Info
  email       String?
  phone       String?
  
  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  country      String?
  
  // Family Relations
  fatherId    String?
  father      Member?  @relation("FatherChildren", fields: [fatherId], references: [id], onDelete: SetNull)
  
  motherId    String?
  mother      Member?  @relation("MotherChildren", fields: [motherId], references: [id], onDelete: SetNull)
  
  // Reverse relations
  childrenAsFather Member[] @relation("FatherChildren")
  childrenAsMother Member[] @relation("MotherChildren")
  
  aliases      String?
  education    String?
  
  role         String   @default("Member") // Admin, Parent, Child, Member
  avatarUrl    String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dues         Due[]
  events       Event[]  @relation("EventAttendees")
  transactions FinancialTransaction[]
  documents    Document[]

  @@map("members")
}

model Due {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  dueDate     DateTime
  status      String   @default("Pending") // Pending, Paid, Overdue
  description String?
  
  memberId    String?
  member      Member?  @relation(fields: [memberId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dues")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  location    String?
  description String?
  type        String?  // Birthday, Anniversary, etc.
  
  attendees   Member[] @relation("EventAttendees")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  @@map("events")
}

model FinancialTransaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // "Income" or "Expense"
  category    String
  date        DateTime
  description String?
  
  members     Member[]
  
  documents   Document[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("financial_transactions")
}

model Document {
  id          String   @id @default(uuid())
  name        String
  url         String
  type        String   // MIME type
  size        Int      // Size in bytes
  
  description String?
  
  transactionId String?
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id])
  
  members       Member[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("documents")
}
